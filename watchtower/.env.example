# ============================================
# Watchtower Backend — Environment Configuration
#
# Copy this file to `.env` in the SAME directory (watchtower/.env)
# NEVER commit the real .env — it is already in .gitignore
#
#   cp watchtower/.env.example watchtower/.env
#
# This file is loaded by watchtower/database/db.py at import time,
# so it applies to app.py, watch.sh, and every watch_*.py script.
# ============================================

# --- MongoDB (REQUIRED) ---
# Everything in watchtower/ fails immediately without this.
#
# Option A: MongoDB Atlas (cloud) — identical behavior in local dev and
# Codespaces since it's just a URL, no local service needed.
# Get this from Atlas > Connect > Drivers.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/watchtower?appName=Cluster0

# Option B: Local MongoDB container (see database/docker-compose.yml,
# profile "local-db"). Start it with:
#   cd watchtower/database && docker compose --profile local-db up -d
# Then use:
# MONGO_URI=mongodb://localhost:27017/watchtower

# --- API Auth (used by app.py's @require_auth and by all frontend calls) ---
# Must match VITE_API_TOKEN in watchtower-frontend/.env
WATCHTOWER_API_TOKEN=

# --- Telegram Notifications (optional) ---
# Used by utils/notify.py (new HTTP / HTTP-change alerts) and by
# xsscanner/xssniper.go (XSS finding alerts). Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Outbound proxy (optional) ---
# Used by utils/notify.py and enum/watch_abuseipdb.py when set.
HTTPS_PROXY=

# --- Enumeration module API keys (optional — each module skips itself
# and logs "credentials not found" if its key is blank) ---
# Used by enum/watch_censys.py
CENSYS_API_ID=
CENSYS_API_SECRET=

# Used by enum/watch_shodan.py
SHODAN_API_KEY=

# Used by enum/watch_chaos.py (ProjectDiscovery Chaos dataset)
CHAOS_API_KEY=