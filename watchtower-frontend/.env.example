# ============================================
# Watchtower Frontend — Environment Configuration
#
# Copy this file to `.env` in the SAME directory (watchtower-frontend/.env)
#   cp watchtower-frontend/.env.example watchtower-frontend/.env
# ============================================

# --- API Connection ---
# از آنجایی که بک‌اند روی VPS موقت اجرا می‌شود، هر بار که سرور جدیدی راه‌اندازی می‌کنید،
# باید IP این متغیر را آپدیت کنید.
# فرمت صحیح: http://<VPS_IP>:3131/api
# می‌توانید این مقدار را دستی تغییر دهید یا از اسکریپت scripts/set-api-url.sh استفاده کنید.
VITE_API_URL=

# --- Analytics (optional, Umami-compatible) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=