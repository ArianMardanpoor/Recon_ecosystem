# ============================================
# Watchtower Frontend — Environment Configuration
#
# Copy this file to `.env` in the SAME directory (watchtower-frontend/.env)
#
#   cp watchtower-frontend/.env.example watchtower-frontend/.env
# ============================================

# --- API Connection ---
# In local dev, the values below match the fallback already hardcoded in
# client/src/api/client.ts, so this is safe to commit as an example.
#
# In dev mode (`pnpm dev`), requests to /api are proxied by Vite
# (see vite.config.ts) to VITE_API_URL, so relative paths work without
# needing to change this even across machines/Codespaces — leave it as-is
# unless you're building for production or pointing at a different host.
VITE_API_URL=

# Must match WATCHTOWER_API_TOKEN in watchtower/.env
VITE_API_TOKEN=

# --- Codespaces note ---
# If you access the API directly from the browser (bypassing the Vite
# dev-server proxy), replace VITE_API_URL with the forwarded Codespaces
# URL for port 3131, e.g.:
#   https://<codespace-name>-3131.app.github.dev/api
# and make sure port 3131's visibility is set to Public (or Private with
# the same auth) in the Codespaces "Ports" tab.

# --- Analytics (optional, Umami-compatible) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=